{% extends 'base.html.twig' %}

{% block title %}Application{% endblock %}

{% block body %}
    <h1>Application</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ application.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ application.name }}</td>
            </tr>
            <tr>
                <th>PackageName</th>
                <td>{{ application.packageName }}</td>
            </tr>
            <tr>
                <th>Note</th>
                <td>{{ application.note }}</td>
            </tr>
            <tr>
                <th>Zařízení</th>
                    <td>
                        {% if application.devices|length > 0 %}
                        <ul>
                            {% for device in application.devices %}
                                <li>
                                    <a href="{{ path('app_device_show', {'id': device.id}) }}">
                                    {{ device.brand }} - {{ device.name }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        Žádné přiřazené zařízení
                    {% endif %}
                    </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_application_index') }}">back to list</a>

    <a href="{{ path('app_application_edit', {'id': application.id}) }}">edit</a>

    {{ include('application/_delete_form.html.twig') }}
{% endblock %}
